-- ==================== CONSTANTS ====================
local COLOR_UPDATE_INTERVAL = 0.3
local TRANSPARENCY_UPDATE_INTERVAL = 0.15
local NORMAL_SPEED = 20
local SPRINT_MULTIPLIER = 2

-- ==================== VARIABLES ====================
