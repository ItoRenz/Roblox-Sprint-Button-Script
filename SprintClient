-- ==================== AVATAR TYPE DETECTION ====================

--- Detect if character is R6 or R15
local function getAvatarType(char)
	local humanoidRig = char:FindFirstChild("Humanoid")
	if humanoidRig then
		if humanoidRig.RigType == Enum.HumanoidRigType.R6 then
			return "R6"
		elseif humanoidRig.RigType == Enum.HumanoidRigType.R15 then
			return "R15"
		end
	end
	
	-- Fallback detection
	if char:FindFirstChild("Right Arm") or char:FindFirstChild("Left Arm") then
		return "R6"
	elseif char:FindFirstChild("RightHand") or char:FindFirstChild("LeftHand") then
		return "R15"
	end
	
	return "R15" -- Default to R15
end

-- ==================== EXTREME OPTIMIZED LIGHTSTICK MANAGEMENT ====================

--- Initialize lightstick array (called once when sprint starts)
local function initializeLightSticks()
	lightStickArray = {}
	
	-- Find all lightstick parts (only once!)
	for _, descendant in ipairs(character:GetDescendants()) do
		if descendant.Name == "LightStick" and descendant:IsA("Part") then
			table.insert(lightStickArray, descendant)
		end
	end
	
	print("Initialized " .. #lightStickArray .. " lightsticks")
end

--- Clear lightstick array
local function clearLightSticks()
	table.clear(lightStickArray)
	lightStickArray = {}
end

--- Monitor new lightsticks (only when sprinting)
local descendantConnection = nil
local function setupLightStickMonitor()
	if descendantConnection then
		descendantConnection:Disconnect()
	end
	
	descendantConnection = character.DescendantAdded:Connect(function(descendant)
		if isSprinting and descendant.Name == "LightStick" and descendant:IsA("Part") then
			table.insert(lightStickArray, descendant)
			print("New lightstick detected")
		end
	end)
end

--- Stop monitoring
local function stopLightStickMonitor()
	if descendantConnection then
		descendantConnection:Disconnect()
		descendantConnection = nil
	end
end

-- ==================== GUI CREATION FUNCTIONS ====================

--- Create UI elements with common properties
local function createUIElement(className, properties)
	local element = Instance.new(className)
	for property, value in pairs(properties) do
		element[property] = value
	end
	return element
end

--- Create shadow effect for button
local function createShadow(parent)
	return createUIElement("TextButton", {
		Name = "Shadow",
		Size = UDim2.new(1, 4, 1, 4),
		Position = UDim2.new(0, 2, 0, 2),
		BackgroundColor3 = Color3.fromRGB(0, 0, 0),
		TextTransparency = 1,
		BorderSizePixel = 0,
		ZIndex = 0,
		Parent = parent
	})
end

--- Update button UI based on sprint state
local function updateButtonUI(button, statusLabel, stroke)
	if isSprinting then
		button.BackgroundColor3 = Color3.fromRGB(255, 100, 150)
		stroke.Color = Color3.fromRGB(255, 200, 200)
		button.Text = "⏸"
		statusLabel.Text = "RUNNING"
		statusLabel.TextColor3 = Color3.fromRGB(255, 100, 150)
	else
		button.BackgroundColor3 = Color3.fromRGB(100, 200, 255)
		stroke.Color = Color3.fromRGB(200, 230, 255)
		button.Text = "▶"
		statusLabel.Text = "WALK"
		statusLabel.TextColor3 = Color3.fromRGB(100, 200, 255)
	end
end

--- EXTREME OPTIMIZATION: Separate coroutine for updates
local function startUpdateLoop()
	if updateCoroutine then
		task.cancel(updateCoroutine)
	end
	
	updateCoroutine = task.spawn(function()
		while isSprinting do
			local currentTime = tick()
			local time = currentTime * 3
			
			-- Update color
			if currentTime - lastColorUpdateTime >= COLOR_UPDATE_INTERVAL then
				currentColor = getRainbowColor(time)
				updateColorEvent:FireServer(currentColor)
				lastColorUpdateTime = currentTime
			end
			
			-- Update transparency
			if currentTime - lastTransparencyUpdateTime >= TRANSPARENCY_UPDATE_INTERVAL then
				local pulse = math.sin(time * 8) * 0.15 + 0.2
				
				-- Clean iteration through array
				local i = 1
				while i <= #lightStickArray do
					local lightStick = lightStickArray[i]
					if lightStick and lightStick.Parent then
						lightStick.Transparency = pulse
						i = i + 1
					else
						-- Remove invalid reference
						table.remove(lightStickArray, i)
					end
				end
				
				lastTransparencyUpdateTime = currentTime
			end
			
			-- Yield to prevent blocking (CRITICAL for performance)
			task.wait(0.03) -- ~30 FPS for updates (smooth enough)
		end
	end)
end

--- Stop update loop
local function stopUpdateLoop()
	if updateCoroutine then
		task.cancel(updateCoroutine)
		updateCoroutine = nil
	end
end

--- Handle sprint toggle
local function toggleSprint()
	isSprinting = not isSprinting
	toggleSprintEvent:FireServer(isSprinting)
	
	if isSprinting then
		-- Start sprint
		task.wait(0.2) -- Wait for server to create lightsticks
		initializeLightSticks()
		setupLightStickMonitor()
		startUpdateLoop()
	else
		-- Stop sprint
		stopUpdateLoop()
		stopLightStickMonitor()
		clearLightSticks()
	end
end

