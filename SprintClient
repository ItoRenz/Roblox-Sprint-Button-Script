local normalSpeed = NORMAL_SPEED
local sprintSpeed = normalSpeed * SPRINT_MULTIPLIER
local currentColor = Color3.fromRGB(255, 0, 0)
local lastColorUpdateTime = 0
local lastTransparencyUpdateTime = 0

-- Platform Detection
local isMobile = UserInputService.TouchEnabled and not UserInputService.KeyboardEnabled
local isPC = not isMobile

-- EXTREME OPTIMIZATION: Array storage for fastest iteration
local lightStickArray = {}
local updateCoroutine = nil

